<Window x:Class="WinDrop.AcceptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Transferencia entrante"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        Topmost="True">

  <StackPanel Margin="28,26,28,22">

    <TextBlock x:Name="HeadlineText"
               FontSize="19" FontWeight="SemiBold"
               TextWrapping="Wrap" Margin="0,0,0,4" />

    <TextBlock x:Name="SubtitleText"
               Opacity="0.6" TextWrapping="Wrap" Margin="0,0,0,16" />

    <Border Background="#0D808080" CornerRadius="8" Padding="14,10" MaxHeight="180">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <ItemsControl x:Name="FileList">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding}" Margin="0,3" TextTrimming="CharacterEllipsis" />
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Border>

    <TextBlock Opacity="0.45" FontSize="11" TextWrapping="Wrap" Margin="0,12,0,0"
               Text="Acepta solo si reconoces al remitente. Los archivos se guardarán en tu carpeta de descargas." />

    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
      <Button Content="Rechazar" Click="OnDecline"
              Padding="22,9" Margin="0,0,10,0" IsCancel="True" MinWidth="100" />
      <Button Content="Aceptar" Click="OnAccept"
              Padding="22,9" IsDefault="True" MinWidth="100" />
    </StackPanel>
  </StackPanel>
</Window>
