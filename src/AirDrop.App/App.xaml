<Application x:Class="WinDrop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WinDrop"
             ShutdownMode="OnMainWindowClose">
  <Application.Resources>
    <ResourceDictionary>

      <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
      <local:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibility" />
      <local:CountToVisibilityConverter x:Key="CountToVisibility" />
      <local:FileSizeConverter x:Key="FileSize" />
      <local:TransferStatusIconConverter x:Key="StatusIcon" />
      <local:TransferStatusBrushConverter x:Key="StatusBrush" />
      <local:RelativeTimeConverter x:Key="RelativeTime" />

      <!-- Botón de navegación de la barra lateral. El estado activo se marca con una barra
           de acento a la izquierda, como en las apps nativas de Windows 11. -->
      <Style x:Key="NavButton" TargetType="RadioButton">
        <Setter Property="GroupName" Value="Nav" />
        <Setter Property="Margin" Value="6,2" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="RadioButton">
              <Border x:Name="Bd"
                      Background="Transparent"
                      CornerRadius="6"
                      Padding="{TemplateBinding Padding}">
                <Grid>
                  <Border x:Name="Accent"
                          Width="3" Height="18"
                          HorizontalAlignment="Left"
                          CornerRadius="2"
                          Margin="-8,0,0,0"
                          Background="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"
                          Opacity="0" />
                  <ContentPresenter VerticalAlignment="Center" />
                </Grid>
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter TargetName="Bd" Property="Background" Value="#14808080" />
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                  <Setter TargetName="Bd" Property="Background" Value="#1F808080" />
                  <Setter TargetName="Accent" Property="Opacity" Value="1" />
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

      <Style x:Key="SectionTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="26" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,0,0,4" />
      </Style>

      <Style x:Key="SectionSubtitle" TargetType="TextBlock">
        <Setter Property="Opacity" Value="0.6" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="Margin" Value="0,0,0,20" />
      </Style>

      <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background" Value="#0D808080" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16" />
      </Style>

      <!-- Aviso persistente sobre la limitación con iPhone. Se define como estilo para que
           aparezca idéntico en todas las secciones donde es relevante. -->
      <Style x:Key="NoticeCard" TargetType="Border" BasedOn="{StaticResource Card}">
        <Setter Property="Background" Value="#22FF9500" />
        <Setter Property="Padding" Value="14" />
      </Style>

    </ResourceDictionary>
  </Application.Resources>
</Application>
