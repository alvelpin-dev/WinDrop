<Window x:Class="WinDrop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WinDrop.ViewModels"
        Title="WinDrop" Height="640" Width="1000"
        MinHeight="520" MinWidth="820"
        AllowDrop="True"
        Drop="OnFilesDropped"
        DragOver="OnDragOver">

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="208" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <!-- ══ Barra lateral ══ -->
    <Border Grid.Column="0" Background="#0A808080">
      <DockPanel>
        <StackPanel DockPanel.Dock="Top" Margin="20,24,20,20">
          <TextBlock Text="WinDrop" FontSize="20" FontWeight="Bold" />
          <TextBlock Text="Protocolo AirDrop" FontSize="12" Opacity="0.5" />
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom" Margin="14,0,14,14">
          <TextBlock Text="{Binding StatusMessage}"
                     FontSize="11" Opacity="0.55"
                     TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Margin="8,0">
          <RadioButton Style="{StaticResource NavButton}"
                       IsChecked="{Binding IsReceiveSection, Mode=OneWay}"
                       Command="{Binding NavigateCommand}"
                       CommandParameter="{x:Static vm:AppSection.Receive}">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#x2193;" FontSize="15" Width="24" />
              <TextBlock Text="Recibir" VerticalAlignment="Center" />
            </StackPanel>
          </RadioButton>

          <RadioButton Style="{StaticResource NavButton}"
                       IsChecked="{Binding IsSendSection, Mode=OneWay}"
                       Command="{Binding NavigateCommand}"
                       CommandParameter="{x:Static vm:AppSection.Send}">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#x2191;" FontSize="15" Width="24" />
              <TextBlock Text="Enviar" VerticalAlignment="Center" />
            </StackPanel>
          </RadioButton>

          <RadioButton Style="{StaticResource NavButton}"
                       IsChecked="{Binding IsWebShareSection, Mode=OneWay}"
                       Command="{Binding NavigateCommand}"
                       CommandParameter="{x:Static vm:AppSection.WebShare}">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#x1F4F1;" FontSize="14" Width="24" />
              <TextBlock Text="iPhone" VerticalAlignment="Center" />
            </StackPanel>
          </RadioButton>

          <Separator Margin="10,10" Opacity="0.2" />

          <RadioButton Style="{StaticResource NavButton}"
                       IsChecked="{Binding IsHistorySection, Mode=OneWay}"
                       Command="{Binding NavigateCommand}"
                       CommandParameter="{x:Static vm:AppSection.History}">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#x21BB;" FontSize="15" Width="24" />
              <TextBlock Text="Historial" VerticalAlignment="Center" />
            </StackPanel>
          </RadioButton>

          <RadioButton Style="{StaticResource NavButton}"
                       IsChecked="{Binding IsSettingsSection, Mode=OneWay}"
                       Command="{Binding NavigateCommand}"
                       CommandParameter="{x:Static vm:AppSection.Settings}">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#x2699;" FontSize="15" Width="24" />
              <TextBlock Text="Ajustes" VerticalAlignment="Center" />
            </StackPanel>
          </RadioButton>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- ══ Contenido ══ -->
    <Grid Grid.Column="1" Margin="32,28,32,24">

      <!-- ─── Recibir ─── -->
      <ScrollViewer VerticalScrollBarVisibility="Auto"
                    Visibility="{Binding IsReceiveSection, Converter={StaticResource BoolToVisibility}}">
        <StackPanel>
          <TextBlock Text="Recibir archivos" Style="{StaticResource SectionTitle}" />
          <TextBlock Style="{StaticResource SectionSubtitle}"
                     Text="Tu equipo se anuncia en la red local usando el protocolo AirDrop." />

          <Border Style="{StaticResource Card}">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>

              <StackPanel VerticalAlignment="Center">
                <TextBlock Text="{Binding Settings.DeviceName}" FontSize="16" FontWeight="SemiBold" />
                <TextBlock Text="{Binding StatusMessage}" Opacity="0.6" FontSize="13" Margin="0,3,0,0" />
              </StackPanel>

              <Button Grid.Column="1"
                      Content="{Binding ReceivingActionText}"
                      Command="{Binding ToggleReceivingCommand}"
                      Padding="22,9" MinWidth="110" />
            </Grid>
          </Border>

          <Border Style="{StaticResource NoticeCard}" Margin="0,16,0,0">
            <StackPanel>
              <TextBlock Text="El iPhone no puede ver este equipo"
                         FontWeight="SemiBold" Margin="0,0,0,6" />
              <TextBlock TextWrapping="Wrap" Opacity="0.85" LineHeight="19">
                AirDrop con dispositivos iOS viaja obligatoriamente sobre AWDL, un protocolo de
                capa 2 propietario que exige inyectar tramas Wi-Fi. Ningún driver de Windows lo
                permite, así que esta limitación no tiene solución por software.
                <LineBreak /><LineBreak />
                Esta sección funciona entre equipos Windows con WinDrop y con implementaciones
                compatibles como OpenDrop. Para transferir con tu iPhone, usa la sección iPhone.
              </TextBlock>
            </StackPanel>
          </Border>

          <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
            <Button Content="Abrir carpeta de descargas"
                    Command="{Binding OpenDownloadFolderCommand}"
                    Padding="16,8" />
          </StackPanel>
        </StackPanel>
      </ScrollViewer>

      <!-- ─── Enviar ─── -->
      <Grid Visibility="{Binding IsSendSection, Converter={StaticResource BoolToVisibility}}">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
          <TextBlock Text="Enviar archivos" Style="{StaticResource SectionTitle}" />
          <TextBlock Style="{StaticResource SectionSubtitle}"
                     Text="Arrastra archivos a la ventana y elige un destino." />
        </StackPanel>

        <Grid Grid.Row="1">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="1.1*" />
          </Grid.ColumnDefinitions>

          <!-- Archivos seleccionados -->
          <DockPanel Grid.Column="0">
            <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
              <TextBlock Text="Archivos" FontWeight="SemiBold" Opacity="0.7" />
              <Button Content="Quitar todos" HorizontalAlignment="Right"
                      Command="{Binding ClearFilesCommand}"
                      Padding="10,3" FontSize="12"
                      Visibility="{Binding SelectedFiles.Count, Converter={StaticResource CountToVisibility}}" />
            </Grid>

            <Border Style="{StaticResource Card}" Padding="4">
              <Grid>
                <TextBlock Text="Arrastra archivos aquí"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Opacity="0.4"
                           Visibility="{Binding SelectedFiles.Count, Converter={StaticResource CountToVisibility}, ConverterParameter=Invert}" />

                <ListBox ItemsSource="{Binding SelectedFiles}"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <Grid Margin="4,3">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Column="1" Opacity="0.5" FontSize="12" Margin="10,0,0,0"
                                   Text="{Binding Length, Converter={StaticResource FileSize}}" />
                      </Grid>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Grid>
            </Border>
          </DockPanel>

          <!-- Dispositivos encontrados -->
          <DockPanel Grid.Column="2">
            <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
              <TextBlock Text="Dispositivos" FontWeight="SemiBold" Opacity="0.7" />
              <Button Content="Buscar" HorizontalAlignment="Right"
                      Command="{Binding RefreshDevicesCommand}"
                      Padding="10,3" FontSize="12" />
            </Grid>

            <Border Style="{StaticResource Card}" Padding="4">
              <Grid>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding Devices.Count, Converter={StaticResource CountToVisibility}, ConverterParameter=Invert}">
                  <TextBlock Text="Buscando dispositivos…" Opacity="0.4" HorizontalAlignment="Center" />
                  <TextBlock Opacity="0.3" FontSize="12" Margin="0,6,0,0"
                             HorizontalAlignment="Center" TextAlignment="Center"
                             Text="Aparecerán aquí otros equipos con WinDrop&#x0a;en la misma red" />
                </StackPanel>

                <ListBox ItemsSource="{Binding Devices}"
                         SelectedItem="{Binding SelectedDevice}"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <StackPanel Orientation="Horizontal" Margin="4,5">
                        <Border Width="34" Height="34" CornerRadius="17"
                                Background="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}">
                          <TextBlock Text="{Binding Initial}"
                                     Foreground="White" FontWeight="SemiBold"
                                     HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                          <TextBlock Text="{Binding DisplayName}" FontWeight="Medium" />
                          <TextBlock Text="{Binding Details}" Opacity="0.5" FontSize="11" />
                        </StackPanel>
                      </StackPanel>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Grid>
            </Border>
          </DockPanel>
        </Grid>

        <!-- Acciones y progreso -->
        <Border Grid.Row="2" Margin="0,16,0,0">
          <StackPanel>
            <Grid Visibility="{Binding IsTransferring, Converter={StaticResource BoolToVisibility}}"
                  Margin="0,0,0,12">
              <StackPanel>
                <TextBlock Text="{Binding ProgressText}" Margin="0,0,0,6" FontSize="13" />
                <ProgressBar Height="4"
                             Value="{Binding ProgressPercent, Mode=OneWay}"
                             IsIndeterminate="{Binding IsProgressIndeterminate}"
                             Maximum="100" />
              </StackPanel>
            </Grid>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
              <Button Content="Cancelar"
                      Command="{Binding CancelSendCommand}"
                      Padding="20,9" Margin="0,0,10,0"
                      Visibility="{Binding IsTransferring, Converter={StaticResource BoolToVisibility}}" />
              <Button Content="Enviar"
                      Command="{Binding SendCommand}"
                      Padding="28,9" MinWidth="120"
                      IsDefault="True" />
            </StackPanel>
          </StackPanel>
        </Border>
      </Grid>

      <!-- ─── iPhone (modo web) ─── -->
      <ScrollViewer VerticalScrollBarVisibility="Auto"
                    Visibility="{Binding IsWebShareSection, Converter={StaticResource BoolToVisibility}}">
        <StackPanel>
          <TextBlock Text="Transferir con el iPhone" Style="{StaticResource SectionTitle}" />
          <TextBlock Style="{StaticResource SectionSubtitle}"
                     Text="Sin instalar nada en el teléfono. Funciona con Safari, que ya viene en iOS." />

          <Border Style="{StaticResource Card}">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>

              <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Servidor web local" FontSize="16" FontWeight="SemiBold" />
                <TextBlock Opacity="0.6" FontSize="13" Margin="0,3,0,0"
                           Text="Comparte los archivos de la sección Enviar y recibe los del iPhone" />
              </StackPanel>

              <Button Grid.Column="1"
                      Content="{Binding WebShareActionText}"
                      Command="{Binding ToggleWebShareCommand}"
                      Padding="22,9" MinWidth="110" />
            </Grid>
          </Border>

          <Border Style="{StaticResource Card}" Margin="0,16,0,0"
                  Visibility="{Binding IsWebShareActive, Converter={StaticResource BoolToVisibility}}">
            <StackPanel>
              <TextBlock Text="Abre esta dirección en el iPhone" FontWeight="SemiBold" Margin="0,0,0,12" />

              <StackPanel Orientation="Horizontal">
                <Border Background="White" Padding="10" CornerRadius="6">
                  <Image x:Name="QrImage" Width="168" Height="168"
                         RenderOptions.BitmapScalingMode="NearestNeighbor" />
                </Border>

                <StackPanel Margin="20,0,0,0" VerticalAlignment="Center">
                  <TextBlock Text="{Binding WebShareUrl}"
                             FontFamily="Consolas" FontSize="17" FontWeight="SemiBold" />
                  <TextBlock Opacity="0.55" FontSize="12" Margin="0,10,0,0" TextWrapping="Wrap"
                             MaxWidth="300" LineHeight="18"
                             Text="Escanea el código con la cámara del iPhone, o escribe la dirección en Safari. El teléfono debe estar en la misma red Wi-Fi." />
                </StackPanel>
              </StackPanel>
            </StackPanel>
          </Border>

          <Border Style="{StaticResource Card}" Margin="0,16,0,0">
            <StackPanel>
              <TextBlock Text="Por qué esto y no AirDrop" FontWeight="SemiBold" Margin="0,0,0,6" />
              <TextBlock TextWrapping="Wrap" Opacity="0.75" LineHeight="19">
                Un iPhone solo hace AirDrop sobre AWDL, y Windows no puede hablar ese protocolo
                porque sus drivers no permiten inyectar tramas Wi-Fi. Se verificó con un iPhone
                real: anuncia otros servicios de Apple en la red, pero nunca AirDrop.
                <LineBreak /><LineBreak />
                Esta vía no es AirDrop y el iPhone no descubre el equipo solo, pero mueve archivos
                en ambos sentidos sin instalar nada y sin que nada salga de la red local.
              </TextBlock>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <!-- ─── Historial ─── -->
      <DockPanel Visibility="{Binding IsHistorySection, Converter={StaticResource BoolToVisibility}}">
        <Grid DockPanel.Dock="Top">
          <StackPanel>
            <TextBlock Text="Historial" Style="{StaticResource SectionTitle}" />
            <TextBlock Style="{StaticResource SectionSubtitle}" Text="Transferencias recientes." />
          </StackPanel>
          <Button Content="Vaciar" HorizontalAlignment="Right" VerticalAlignment="Top"
                  Command="{Binding ClearHistoryCommand}" Padding="16,7" />
        </Grid>

        <Grid>
          <TextBlock Text="Todavía no hay transferencias"
                     HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.4"
                     Visibility="{Binding History.Entries.Count, Converter={StaticResource CountToVisibility}, ConverterParameter=Invert}" />

          <ListBox ItemsSource="{Binding History.Entries}"
                   Background="Transparent" BorderThickness="0"
                   ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Grid Margin="4,7">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>

                  <TextBlock Grid.Column="0" FontSize="17" Width="30"
                             VerticalAlignment="Center"
                             Text="{Binding Status, Converter={StaticResource StatusIcon}}"
                             Foreground="{Binding Status, Converter={StaticResource StatusBrush}}" />

                  <StackPanel Grid.Column="1">
                    <TextBlock Text="{Binding Summary}" TextTrimming="CharacterEllipsis" />
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                      <TextBlock Text="{Binding Direction}" Opacity="0.5" FontSize="11" />
                      <TextBlock Text=" · " Opacity="0.5" FontSize="11" />
                      <TextBlock Text="{Binding PeerName}" Opacity="0.5" FontSize="11" />
                    </StackPanel>
                  </StackPanel>

                  <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock Opacity="0.5" FontSize="11" HorizontalAlignment="Right"
                               Text="{Binding Timestamp, Converter={StaticResource RelativeTime}}" />
                    <TextBlock Opacity="0.4" FontSize="11" HorizontalAlignment="Right"
                               Text="{Binding TotalBytes, Converter={StaticResource FileSize}}" />
                  </StackPanel>
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </DockPanel>

      <!-- ─── Ajustes ─── -->
      <ScrollViewer VerticalScrollBarVisibility="Auto"
                    Visibility="{Binding IsSettingsSection, Converter={StaticResource BoolToVisibility}}">
        <StackPanel MaxWidth="560" HorizontalAlignment="Left">
          <TextBlock Text="Ajustes" Style="{StaticResource SectionTitle}" />
          <TextBlock Style="{StaticResource SectionSubtitle}" Text="Preferencias de la aplicación." />

          <TextBlock Text="Nombre del dispositivo" FontWeight="SemiBold" Margin="0,0,0,6" />
          <TextBox Text="{Binding Settings.DeviceName, UpdateSourceTrigger=PropertyChanged}"
                   Padding="10,8" />
          <TextBlock Opacity="0.5" FontSize="12" Margin="0,5,0,20"
                     Text="Así te verán los demás dispositivos." />

          <TextBlock Text="Carpeta de destino" FontWeight="SemiBold" Margin="0,0,0,6" />
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Text="{Binding Settings.DownloadFolder, UpdateSourceTrigger=PropertyChanged}"
                     Padding="10,8" />
            <Button Grid.Column="1" Content="Examinar…" Margin="8,0,0,0" Padding="14,8"
                    Click="OnBrowseFolder" />
          </Grid>

          <TextBlock Text="Visibilidad" FontWeight="SemiBold" Margin="0,22,0,8" />
          <RadioButton x:Name="VisibilityEveryone" Content="Todos" GroupName="Visibility"
                       Margin="0,0,0,6" Checked="OnVisibilityChanged" />
          <RadioButton x:Name="VisibilityOff" Content="Desactivado" GroupName="Visibility"
                       Margin="0,0,0,6" Checked="OnVisibilityChanged" />
          <RadioButton IsEnabled="False" Margin="0,0,0,4">
            <StackPanel>
              <TextBlock Text="Solo contactos" />
              <TextBlock Opacity="0.5" FontSize="11" TextWrapping="Wrap" MaxWidth="480"
                         Text="No disponible: requiere un certificado de identidad de Apple ID firmado por Apple, que no puede generarse fuera de sus dispositivos." />
            </StackPanel>
          </RadioButton>

          <TextBlock Text="Notificaciones" FontWeight="SemiBold" Margin="0,22,0,8" />
          <CheckBox Content="Mostrar notificación al recibir un archivo"
                    IsChecked="{Binding Settings.ShowNotifications}" Margin="0,0,0,6" />
          <CheckBox Content="Reproducir un sonido"
                    IsChecked="{Binding Settings.PlaySound}" Margin="0,0,0,6" />
          <CheckBox Content="Activar la recepción al abrir la aplicación"
                    IsChecked="{Binding Settings.StartReceivingOnLaunch}" />

          <Button Content="Guardar" Command="{Binding SaveSettingsCommand}"
                  HorizontalAlignment="Left" Padding="28,9" Margin="0,26,0,0" />
        </StackPanel>
      </ScrollViewer>

    </Grid>
  </Grid>
</Window>
